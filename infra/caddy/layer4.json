{
  "apps": {
    "layer4": {
      "servers": {

        "kafka_tls": {
          "listen": ["0.0.0.0:9093"],
          "routes": [
            {
              "match": [
                {
                  "tls": {}
                }
              ],
              "handle": [
                {
                  "handler": "tls",
                  "connection_policies": [
                    {
                      "certificate_selection": {
                        "any_tag": ["kafka_internal"]
                      },
                      "client_authentication": {
                        "mode": "require_and_verify",
                        "trusted_ca_certs_pem_files": ["/etc/caddy/certs/internal-ca.pem"]
                      }
                    }
                  ]
                },
                {
                  "handler": "proxy",
                  "upstreams": [
                    { "dial": ["kafka:9092"] }
                  ]
                }
              ]
            }
          ]
        },

        "tigerbeetle_tls": {
