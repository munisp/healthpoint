{
  "realm": "nsa-idr-platform",
  "displayName": "HealthPoint NSA/IDR Platform",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername(undefined)",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Platform administrator with full access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "provider",
        "description": "Healthcare provider (physician, facility, group practice)",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "health_plan",
        "description": "Health plan or insurer representative",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "idr_entity",
        "description": "Certified IDR entity authorized to issue determinations",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "aggregator",
        "description": "Third-party aggregator or billing service",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "auditor",
        "description": "Compliance auditor with read-only access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "patient",
        "description": "Patient or member accessing their own records",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "cms_regulator",
        "description": "CMS regulatory oversight access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "user",
        "description": "Default authenticated user",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "groups": [
    {
      "name": "Providers",
      "path": "/Providers",
      "realmRoles": [
        "provider",
        "user"
      ]
    },
    {
      "name": "HealthPlans",
      "path": "/HealthPlans",
      "realmRoles": [
        "health_plan",
        "user"
      ]
    },
    {
      "name": "IDREntities",
      "path": "/IDREntities",
      "realmRoles": [
        "idr_entity",
        "user"
      ]
    },
    {
      "name": "Administrators",
      "path": "/Administrators",
      "realmRoles": [
        "admin",
        "user"
      ]
    },
    {
      "name": "Auditors",
      "path": "/Auditors",
      "realmRoles": [
        "auditor",
        "user"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "healthpoint-frontend",
      "name": "HealthPoint Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*",
        "https://healthpoint.example.com/*",
        "${FRONTEND_URL}/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "https://healthpoint.example.com",
        "${FRONTEND_URL}"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ]
    },
    {
      "clientId": "healthpoint-backend",
      "name": "HealthPoint Backend Services",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "bearerOnly": false,
      "protocol": "openid-connect",
      "secret": "${KEYCLOAK_BACKEND_CLIENT_SECRET}",
      "attributes": {
        "access.token.lifespan": "300"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    },
    {
      "clientId": "apisix-gateway",
      "name": "APISIX API Gateway",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect",
      "secret": "${KEYCLOAK_APISIX_CLIENT_SECRET}",
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "tenant_id",
      "description": "Tenant identifier for multi-tenancy",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "platform-admin",
      "email": "admin@healthpoint.example.com",
      "firstName": "Platform",
      "lastName": "Administrator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${ADMIN_INITIAL_PASSWORD}",
          "temporary": true
        }
      ],
      "realmRoles": [
        "admin",
        "user"
      ],
      "groups": [
        "/Administrators"
      ],
      "attributes": {
        "tenant_id": [
          "system"
        ]
      }
    },
    {
      "username": "test-provider",
      "email": "provider@healthpoint.example.com",
      "firstName": "Test",
      "lastName": "Provider",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${PROVIDER_TEST_PASSWORD}",
          "temporary": true
        }
      ],
      "realmRoles": [
        "provider",
        "user"
      ],
      "groups": [
        "/Providers"
      ],
      "attributes": {
        "tenant_id": [
          "test-tenant-001"
        ],
        "provider_npi": [
          "1234567890"
        ]
      }
    },
    {
      "username": "test-health-plan",
      "email": "plan@healthpoint.example.com",
      "firstName": "Test",
      "lastName": "HealthPlan",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${PLAN_TEST_PASSWORD}",
          "temporary": true
        }
      ],
      "realmRoles": [
        "health_plan",
        "user"
      ],
      "groups": [
        "/HealthPlans"
      ],
      "attributes": {
        "tenant_id": [
          "test-tenant-001"
        ]
      }
    },
    {
      "username": "test-idr-entity",
      "email": "idr@healthpoint.example.com",
      "firstName": "Test",
      "lastName": "IDREntity",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${IDR_ENTITY_TEST_PASSWORD}",
          "temporary": true
        }
      ],
      "realmRoles": [
        "idr_entity",
        "user"
      ],
      "groups": [
        "/IDREntities"
      ],
      "attributes": {
        "tenant_id": [
          "system"
        ]
      }
    }
  ],
  "eventsEnabled": true,
  "eventsListeners": [
    "jboss-logging"
  ],
  "enabledEventTypes": [
    "LOGIN",
    "LOGIN_ERROR",
    "LOGOUT",
    "LOGOUT_ERROR",
    "REGISTER",
    "REGISTER_ERROR",
    "UPDATE_PASSWORD",
    "UPDATE_PASSWORD_ERROR",
    "CLIENT_LOGIN",
    "CLIENT_LOGIN_ERROR",
    "CODE_TO_TOKEN",
    "CODE_TO_TOKEN_ERROR",
    "RESET_PASSWORD",
    "RESET_PASSWORD_ERROR",
    "VERIFY_EMAIL",
    "VERIFY_EMAIL_ERROR"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true
}